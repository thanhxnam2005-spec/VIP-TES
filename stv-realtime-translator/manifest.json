{
  "name": "Browser Screen Translator",
  "version": "2.0.0",
  "manifest_version": 3,
  "description": "Auto-translate web pages from Chinese, English, Japanese, Korean and more to Vietnamese using Google Translate.",
  "homepage_url": "https://sangtacviet.com/",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "contextMenus",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "all_frames": true,
      "js": [
        "src/inject/inject.js"
      ]
    }
  ],
  "background": {
    "service_worker": "src/inject/background.js"
  },
  "action": {
    "default_icon": "icons/icon48.png",
    "default_title": "Browser Screen Translator",
    "default_popup": "src/browser_action/browser_action.html"
  }
}
