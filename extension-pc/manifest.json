{
  "manifest_version": 3,
  "name": "Novel Studio Connector (PC)",
  "version": "1.0",
  "description": "Stealth novel scraper with proxy rotation & anti-bot",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "proxy",
    "webRequest",
    "webRequestAuthProvider"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Novel Studio Connector"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "externally_connectable": {
    "matches": [
      "https://thienthu.vipg.workers.dev/*",
      "https://*.workers.dev/*",
      "http://localhost/*",
      "https://localhost/*"
    ]
  }
}
